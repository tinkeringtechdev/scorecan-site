# Block dotfiles and config from HTTP.
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
<FilesMatch "^(config|bootstrap)\.php$">
    Require all denied
</FilesMatch>

# Default landing page.
DirectoryIndex index.php

# Pretty-print PHP errors only locally; quiet on production (cPanel).
php_flag display_errors Off

# UTF-8.
AddDefaultCharset UTF-8
